# Cloud TTS API keys for `whistle cloud-synth`.
# Copy this file to `.env` (which is gitignored) and fill in the values.
# The CLI auto-loads .env at startup via python-dotenv.

# ElevenLabs - https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini - https://aistudio.google.com/apikey
# Either GEMINI_API_KEY or GOOGLE_API_KEY works.
GEMINI_API_KEY=
